{
	"name": "@navaja/web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev --webpack --hostname 0.0.0.0 --port 3000",
		"build": "next build",
		"start": "next start",
		"seed:real-metrics": "node scripts/seed-real-metrics-data.mjs",
		"payments:reconcile": "node --experimental-strip-types scripts/reconcile-payment-intents.mjs",
		"start:test": "pnpm exec next start --hostname 127.0.0.1 --port 3100",
		"e2e:serve": "pnpm run build && pnpm run start:test",
		"lint": "node ../../node_modules/eslint/bin/eslint.js . --ext .ts,.tsx",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "pnpm run test:unit && pnpm run test:integration",
		"test:unit": "pnpm exec vitest run test/unit",
		"test:integration": "pnpm exec vitest run test/integration",
		"test:e2e": "pnpm exec playwright test",
		"coverage": "pnpm exec vitest run --coverage"
	},
	"dependencies": {
