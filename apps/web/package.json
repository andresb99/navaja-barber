		"@internationalized/date": "^3.12.0",
		"@navaja/shared": "workspace:*",
		"@supabase/ssr": "^0.5.2",
		"@supabase/supabase-js": "^2.49.1",
		"apexcharts": "^5.10.3",
		"clsx": "^2.1.1",
